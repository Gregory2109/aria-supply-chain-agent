# Local dev:
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/supplychain

# Supabase (free production) — use the SESSION POOLER URL, not the direct connection.
# The direct connection (db.[ref].supabase.co) is IPv6-only and unreachable from HF Spaces.
# Get it from: Supabase dashboard → Settings → Database → Session pooler tab
# DATABASE_URL=postgresql+psycopg2://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Note: URL-encode special chars in the password (e.g. ! → %21) when using a connection URL.

# Redis: set REDIS_URL for managed Redis (Upstash free tier: rediss://default:[pw]@[host].upstash.io:6380)
# or use REDIS_HOST/REDIS_PORT for local dev (defaults to localhost:6379)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM backend: "ollama" (default, local dev) or "groq" (hosted, used in production)
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Required in production to protect POST /reindex and GET /cache/clear.
# Leave unset locally — auth is skipped (with a startup warning) when this is empty.
ARIA_API_KEY=

# SAP S/4HANA Cloud — live data source (leave blank to use mock data locally)
# SAP_USERNAME / SAP_PASSWORD must be a Communication User created in the
# SAP Fiori launchpad. Required scenarios: SAP_COM_0001, SAP_COM_0164, SAP_COM_0008
SAP_BASE_URL=https://my413615.s4hana.cloud.sap
SAP_USERNAME=
SAP_PASSWORD=
SAP_CLIENT=100

LANGCHAIN_TRACING_V2=false
LANGCHAIN_TELEMETRY=false
HF_HUB_DISABLE_TELEMETRY=1
TOKENIZERS_PARALLELISM=false
