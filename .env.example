DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/supplychain

# Redis: either set REDIS_URL (e.g. managed Redis on Render) or REDIS_HOST/REDIS_PORT (local dev default)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM backend: "ollama" (default, local dev) or "groq" (hosted, used in production)
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Required in production to protect POST /reindex and GET /cache/clear.
# Leave unset locally — auth is skipped (with a startup warning) when this is empty.
ARIA_API_KEY=

LANGCHAIN_TRACING_V2=false
LANGCHAIN_TELEMETRY=false
HF_HUB_DISABLE_TELEMETRY=1
TOKENIZERS_PARALLELISM=false
